            className={`flex items-center gap-3 rounded-app px-4 py-3 text-sm font-bold transition-colors ${
              active ? "bg-gold text-navy-dark" : "text-navy/70 hover:bg-gold/10"
            }`}
          >
            {item.imageSrc ? (
              <Image
                src={item.imageSrc}
                alt={item.label}
                width={20}
                height={20}
                className={active ? "opacity-100" : "opacity-50"}
              />
            ) : Icon ? (
              <Icon size={20} strokeWidth={2.25} />
            ) : null}
            {item.label}
          </Link>
        );
      })}

      <div className="mt-auto flex items-center gap-2 px-4 py-3 text-navy/40">
        <Image
          src="/icons/matty-icon-96.png"
          alt=""
          width={24}
          height={24}
          className="rounded-full"
        />
        <div className="leading-tight">
          <p className="text-xs font-bold">MATTY</p>
          <p className="text-[10px]">Ver. 1.2.0</p>
        </div>
      </div>
