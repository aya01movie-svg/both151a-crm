          <Card>
            <CardTitle>メモ履歴</CardTitle>
            {notes.length === 0 && (
              <p className="text-navy/40 text-sm">メモはまだありません。</p>
            )}
            <ul className="flex flex-col gap-2 max-h-52 overflow-y-auto">
              {notes.map((n) => (
                <li key={n.id} className="text-sm border-b border-navy/5 pb-2 last:border-0">
                  <div className="flex items-center justify-between gap-2">
                    <p className="text-navy/40 text-xs mb-0.5">
                      {formatDateTime(n.created_at)}
                      {n.authorName ? `・${n.authorName}` : ""}
                    </p>
                    {profile.role === "admin" && (
                      <InvalidateNoteButton noteId={n.id} customerId={customer.id} />
                    )}
                  </div>
                  <p className="text-navy whitespace-pre-wrap">{n.note}</p>
                </li>
              ))}
            </ul>
            <NoteForm customerId={customer.id} />
          </Card>
        </div>
      </div>

      <div className="mt-4">
        <CustomerTimeline events={timelineEvents} />
      </div>
    </>
  );
}
</file>

<file path="src/app/globals.css">
@import "tailwindcss";

/*
  MATTY デザイントークン
  背景: 白 / 薄いベージュ
  ブランドカラー: MATTYのアイコン背景と同じ黄色（--color-brand が唯一の基準値）
  警告: オレンジ　期限切れ: 赤　成功: グリーン
  角丸: 12px　ボタン高さ: 56px以上　文字サイズ: 16px以上

  【テーマカラーの変更方法】
  将来アイコン（MATTY）のデザインが変わった場合は、--color-brand の値だけを
  変更してください。ヘッダー・アクセントボタン（gold系）はすべて
  --color-brand を参照しているため、1箇所の変更で全体に反映されます。
*/

:root {
  --color-navy: #16213e;
  --color-navy-dark: #0d1526;
  --color-navy-light: #2a3a63;

  /* ブランドカラーの基準値（MATTYのアイコン背景の黄色 rgb(254,236,3)） */
  --color-brand: #FEEC03;
  --color-brand-dark: #d9c900;

  /* gold系はブランドカラーをそのまま使う（既存のボタン・強調表示すべてに反映される） */
  --color-gold: var(--color-brand);
  --color-gold-dark: var(--color-brand-dark);

  --color-beige: #f6f1e7;
  --color-beige-dark: #ece4d2;
  --color-warn: #e07b2b;
  --color-danger: #dc2626;
  --color-success: #1f9d55;
  --color-info: #2f6fb0;

  --background: #ffffff;
  --foreground: var(--color-navy);
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);

  --color-navy: var(--color-navy);
  --color-navy-dark: var(--color-navy-dark);
  --color-navy-light: var(--color-navy-light);
  --color-brand: var(--color-brand);
  --color-brand-dark: var(--color-brand-dark);
  --color-gold: var(--color-gold);
  --color-gold-dark: var(--color-gold-dark);
  --color-beige: var(--color-beige);
  --color-beige-dark: var(--color-beige-dark);
  --color-warn: var(--color-warn);
  --color-danger: var(--color-danger);
  --color-success: var(--color-success);
  --color-info: var(--color-info);

  --font-sans: system-ui, "Hiragino Kaku Gothic ProN", "Hiragino Sans", "Yu Gothic",
    "Noto Sans JP", "Roboto", "Droid Sans", sans-serif;

  --radius-app: 12px;
}

/* 古いAndroidタブレットでも軽快に動作させるため、装飾的なアニメーションは最小限にする */
* {
  -webkit-tap-highlight-color: transparent;
}

html {
  font-size: 16px;
}

body {
  background: var(--color-beige);
  color: var(--color-navy);
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
}

/* すべてのボタンは56px以上・角丸12pxを基本とする（第20章・第34章） */
.btn-base {
  min-height: 56px;
  border-radius: var(--radius-app);
  font-weight: 700;
  font-size: 1rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  transition: opacity 0.15s ease, transform 0.05s ease;
  touch-action: manipulation;
}

.btn-base:active {
  transform: scale(0.98);
}

.card-base {
  background: #ffffff;
  border-radius: var(--radius-app);
  box-shadow: 0 1px 3px rgba(22, 33, 62, 0.08);
}
</file>

