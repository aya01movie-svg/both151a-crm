import { InputHTMLAttributes, forwardRef } from "react";

type TextFieldProps = InputHTMLAttributes<HTMLInputElement> & {
  label: string;
};

/**
 * ラベル付きテキスト入力。タブレットでの操作性を優先し、
 * 高さ・文字サイズを大きめに固定する。
 */
