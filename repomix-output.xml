import { addChampagneAction } from "@/lib/actions/bottles";
import { Button } from "@/components/ui/Button";

const CHAMPAGNE_CANDIDATES = [
  "モエ ブリュット",
  "モエ ロゼ",
  "ドンペリ ブリュット",
  "ドンペリ ロゼ",
  "ローランペリエ",
  "クリュッグ",
  "ヴーヴクリコ",
  "ポルロジェ",
  "テタンジェ",
  "ボランジェ",
