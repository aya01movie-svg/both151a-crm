        <div ref={calFormRef} className="flex flex-col gap-3 p-4 rounded-app border-2 border-info/40 bg-info/5">
          <p className="text-xs font-black text-info">＋カレンダーに反映させたいイベント</p>

          {/* タイトル + 絵文字 */}
          <div className="flex items-end gap-2">
