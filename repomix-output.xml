"use client";

import { useEffect } from "react";

/**
 * RC2追加: 想定外のエラーが発生した場合でも「真っ白画面」にならないよう、
 * アプリ全体の共通エラーバウンダリを追加する。
 * これはあくまで保険であり、根本原因（Hydration Error等）は個別に修正済み。
 */
export default function Error({
  error,
  reset,
}: {
  error: Error & { digest?: string };
  reset: () => void;
}) {
  useEffect(() => {
    console.error(error);
  }, [error]);

  return (
