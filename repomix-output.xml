}
.btn-sample.gold { background: #d9a536; color: #22304a; }
.btn-sample.outline { background: #fff; color: #22304a; border: 2px solid #22304a; }
.btn-sample.danger { background: #c33a3a; color: #fff; }

/* 注意ボックス */
.note {
  background: #fff6e0;
  border: 2px solid #f0d383;
  border-radius: 12px;
  padding: 14px 16px;
  margin: 14px 0;
  font-size: 16px;
}
.note.warn { background: #fdecec; border-color: #eeb3b3; }
.note strong { color: #a6371f; }

/* やりたいこと カード（トップページ） */
.goal-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.goal-card {
  display: block;
  background: #fff;
  border: 2px solid #eee1c4;
  border-radius: 14px;
  padding: 16px 18px;
  text-decoration: none;
  color: #22304a;
}
.goal-card:hover, .goal-card:active { border-color: #d9a536; }
.goal-card .q {
  font-size: 18px;
  font-weight: bold;
  display: block;
  margin-bottom: 4px;
}
.goal-card .a {
  font-size: 15px;
  color: #5a6784;
}

/* 目次ページ用リスト */
.toc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.toc-list a {
  display: block;
  background: #fff;
  border: 1px solid #eee1c4;
  border-radius: 12px;
  padding: 14px 16px;
  text-decoration: none;
  color: #22304a;
  font-weight: bold;
}
.toc-list a:hover, .toc-list a:active { border-color: #d9a536; }
.toc-num { color: #b98a1a; margin-right: 6px; }

/* ページ送り */
.pager {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  margin: 30px 0 10px;
  flex-wrap: wrap;
}
.pager a {
  flex: 1;
  min-width: 140px;
  text-align: center;
  background: #22304a;
  color: #fff;
  text-decoration: none;
  font-weight: bold;
  padding: 16px 10px;
  border-radius: 12px;
  min-height: 44px;
}
.pager a.secondary {
  background: #fff;
  color: #22304a;
  border: 2px solid #22304a;
}
.pager a:hover, .pager a:active { opacity: 0.85; }

/* チェックリスト */
.check-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background: #fff;
  border: 1px solid #eee1c4;
  border-radius: 12px;
  padding: 14px 16px;
  margin-bottom: 10px;
}
.check-item input[type="checkbox"] {
  width: 28px;
  height: 28px;
  margin: 2px 0 0;
  flex-shrink: 0;
}
.check-item label { font-size: 17px; }

/* フッター */
.site-footer {
  text-align: center;
  color: #8a7a52;
  font-size: 13px;
  padding: 20px 0 30px;
}

/* 印刷対応 */
@media print {
  .top-bar, .pager, .no-print { display: none !important; }
  body { background: #fff; color: #000; font-size: 13pt; }
  .card, .step-card { border: 1px solid #999; box-shadow: none; page-break-inside: avoid; }
  a { color: #000; text-decoration: underline; }
  .shot { border-color: #000; }
}

/* 横スクロール防止 */
.wrap, .card, .step-card { max-width: 100%; }
</file>

<file path="public/guide/assets/js/main.js">
// MATTY 使い方ガイド 補助スクリプト（無くても本文は読めます）
// チェックリストの状態だけを保存します。古いブラウザでも動くよう、
// try/catch で囲み、対応していない場合は何もしません。
(function () {
  try {
    var boxes = document.querySelectorAll('.check-item input[type="checkbox"]');
    if (!boxes || boxes.length === 0) return;

    for (var i = 0; i < boxes.length; i++) {
      var box = boxes[i];
      var key = 'matty-guide-check-' + box.id;
      var saved = window.localStorage ? window.localStorage.getItem(key) : null;
      if (saved === '1') box.checked = true;
      box.addEventListener('change', (function (k, b) {
        return function () {
          try {
            if (window.localStorage) {
              window.localStorage.setItem(k, b.checked ? '1' : '0');
            }
          } catch (e) {}
        };
      })(key, box));
    }
  } catch (e) {
    // 何もしない（本文の閲覧には影響しません）
  }
})();
</file>

