    actorName: log.actor_id ? nameById.get(log.actor_id) ?? "不明" : "システム",
    actionLabel: ACTION_LABEL[log.action] ?? log.action,
    tableLabel: TABLE_LABEL[log.table_name] ?? log.table_name,
  }));
